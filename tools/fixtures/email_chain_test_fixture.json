  "feature_flag_test_matrix": {
    "description": "Test each SOCFWFeatureFlags gate independently. Run SC-01 as base. Set flag to true and re-run to validate the gated capability activates.",
    "flags": {
      "sandbox_detonation": {
        "scenario": "SC-02 (attachment threat)",
        "set": "sandbox_detonation.enabled = true in SOCFWFeatureFlags",
        "expected": "Endpoint Verdict Resolution task 48 gate evaluates true \u2192 task 18 SOCCommandWrapper soc-detonate-file executes",
        "validate_in": "xsiam_socfw_ir_execution_raw \u2014 look for action=soc-detonate-file, execution_mode=shadow"
      },
      "email_authentication": {
        "scenario": "SC-01 (add EmailHeaders to context_seed)",
        "set": "email_authentication.enabled = true in SOCFWFeatureFlags",
        "expected": "Signal Char task 30 gate evaluates true \u2192 task 31 CheckEmailAuthenticity runs",
        "additional_seed": "!SetAndHandleEmpty key=inputs.EmailHeaders value=\"Received: from mail.example.com; DKIM-Signature: v=1; SPF: pass\"",
        "validate_in": "warroom \u2014 CheckEmailAuthenticity task entry appears"
      },
      "email_header_scoring": {
        "scenario": "SC-01 (add EmailHeaders to context_seed)",
        "set": "email_header_scoring.enabled = true in SOCFWFeatureFlags",
        "expected": "Signal Char task 34 gate evaluates true \u2192 task 35 Process Mail Infrastructure Headers runs",
        "additional_seed": "!SetAndHandleEmpty key=inputs.EmailHeaders value=\"X-Forefront-Antispam-Report: SCL:9; BCL:0; PTR:198.51.100.77\"",
