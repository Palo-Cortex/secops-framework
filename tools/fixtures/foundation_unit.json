[
  {
    "name": "Dedup \u2014 no similar alerts found \u2192 passes through to Done",
    "playbook": "Foundation_-_Dedup",
    "category": "foundation",
    "suite": "unit",
    "tags": [
      "happy_path"
    ],
    "context_inputs": {
      "parentIncidentFields.incident_id": "INC-001",
      "DBotFindSimilarIncidents.isSimilarIncidentFound": false
    },
    "uc_mocks": {},
    "sub_mocks": {},
    "assertions": [
      {
        "type": "branch_taken",
        "target": "16",
        "expected": "#default#",
        "description": "No similar alerts \u2192 default path \u2192 Done without closing"
      },
      {
        "type": "task_not_executed",
        "target": "14",
        "description": "Close As Duplicates must NOT run when no duplicate found"
      },
      {
        "type": "task_not_executed",
        "target": "15",
        "description": "Print Duplicate Alerts must NOT run"
      }
    ]
  },
  {
    "name": "Dedup \u2014 duplicate found \u2192 prints warning and closes duplicate",
    "playbook": "Foundation_-_Dedup",
    "category": "foundation",
