      "alert.id": "INC-002",
      "DBotFindSimilarIncidents.isSimilarIncidentFound": true,
      "DBotFindSimilarIncidents.similarIncident": {
        "id": "INC-001"
      }
    },
    "uc_mocks": {},
    "sub_mocks": {},
    "assertions": [
      {
        "type": "branch_taken",
        "target": "16",
        "expected": "yes",
        "description": "Duplicate found \u2192 yes branch"
      },
      {
        "type": "task_executed",
        "target": "15",
        "description": "Print Duplicate Alerts must run"
      },
      {
        "type": "task_executed",
        "target": "14",
        "description": "Close As Duplicates must run"
      }
    ]
  },
