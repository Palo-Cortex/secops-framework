    "soc-block-sender": {
        "responses": {
            "Mimecast": {
                "command": "mimecast-create-blocked-sender-policy",
                "inline_args": {
                    "sender": "SOCFramework.Artifacts.Email.From",
                    "description": "Blocked by SOC Framework \u2014 threat sender"
                }
            },
            "Microsoft Defender Advanced Threat Protection": {
                "command": "microsoft-atp-add-tiindicator",
                "inline_args": {
                    "indicator_value": "SOCFramework.Artifacts.Email.From",
                    "indicator_type": "EmailSenderAddress",
                    "action": "BlockAndRemediate",
                    "description": "SOCFramework block sender",
                    "expiration_date_time": "90"
                }
            },
            "Proofpoint TAP v2": {
                "command": "proofpoint-block-sender",
                "inline_args": {
                    "sender_address": "SOCFramework.Artifacts.Email.From",
                    "action": "block"
                }
            }
        },
        "output_map": {
            "UC.Email.BlockSender.status": "Mimecast.BlockedSender.status",
            "UC.Email.BlockSender.message": "Mimecast.BlockedSender.message"
        }
    },
    "soc-unblock-sender": {
        "responses": {
            "Mimecast": {
                "command": "mimecast-delete-blocked-sender-policy",
                "inline_args": {
                    "sender": "SOCFramework.Artifacts.Email.From"
                }
            },
            "Microsoft Defender Advanced Threat Protection": {
                "command": "microsoft-atp-sc-delete-indicator",
                "inline_args": {
                    "indicator_value": "SOCFramework.Artifacts.Email.From"
                }
            },
            "Proofpoint TAP v2": {
                "command": "proofpoint-delete-blocked-sender",
                "inline_args": {
                    "sender": "SOCFramework.Artifacts.Email.From"
                }
            }
        },
        "phase": "Recovery",
        "category": "Email",
        "description": "Remove a blocked sender entry. Used in Recovery phase when a false positive is confirmed.",
        "output_map": {
            "UC.Email.UnblockSender.status": "Mimecast.DeleteBlockedSender.status",
            "UC.Email.UnblockSender.message": "Mimecast.DeleteBlockedSender.message"
        }
    },
